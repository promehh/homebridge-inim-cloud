{
  "pluginAlias": "InimCloud",
  "pluginType": "accessory",
  "singular": false,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Nome accessorio",
        "type": "string",
        "default": "Allarme Casa",
        "required": true
      },
      "email": {
        "title": "Email account INIM Cloud",
        "type": "string",
        "required": true
      },
      "password": {
        "title": "Password account INIM Cloud",
        "type": "string",
        "required": true
      },
      "userCode": {
        "title": "PIN utente allarme (codice tastiera)",
        "type": "string",
        "required": true
      },
      "deviceIndex": {
        "title": "Indice centrale (0 = prima centrale)",
        "type": "integer",
        "default": 0
      },
      "armScenario": {
        "title": "ID scenario inserimento totale",
        "type": "integer",
        "default": 1
      },
      "disarmScenario": {
        "title": "ID scenario disinserimento",
        "type": "integer",
        "default": 0
      },
      "pollInterval": {
        "title": "Intervallo aggiornamento stato (secondi)",
        "type": "integer",
        "default": 15
      }
    }
  }
}
