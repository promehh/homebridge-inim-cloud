{
  "pluginAlias": "InimCloud",
  "pluginType": "accessory",
  "singular": false,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Nome accessorio",
        "type": "string",
        "default": "Allarme Casa",
        "required": true
      },
      "email": {
        "title": "Email account INIM Cloud",
        "type": "string",
        "required": true
      },
      "password": {
        "title": "Password account INIM Cloud",
        "type": "string",
        "required": true
      },
      "userCode": {
        "title": "PIN utente allarme (codice tastiera)",
        "type": "string",
        "required": true
      },
      "scenarioDisarmed": {
        "title": "Scenario INIM → Disarmato (HomeKit)",
        "type": "integer",
        "default": 0,
        "description": "ID scenario INIM per stato Disarmato"
      },
      "scenarioHome": {
        "title": "Scenario INIM → Casa (HomeKit)",
        "type": "integer",
        "default": 1,
        "description": "ID scenario INIM per stato Casa (Stay Armed)"
      },
      "scenarioNight": {
        "title": "Scenario INIM → Notte (HomeKit)",
        "type": "integer",
        "default": 2,
        "description": "ID scenario INIM per stato Notte (Night Armed)"
      },
      "scenarioAway": {
        "title": "Scenario INIM → Fuori (HomeKit)",
        "type": "integer",
        "default": 3,
        "description": "ID scenario INIM per stato Fuori (Away Armed)"
      },
      "pollInterval": {
        "title": "Intervallo aggiornamento stato (secondi)",
        "type": "integer",
        "default": 15,
        "minimum": 5
      }
    }
  },
  "layout": [
    {
      "type": "section",
      "title": "Credenziali INIM Cloud",
      "items": ["name", "email", "password", "userCode"]
    },
    {
      "type": "section",
      "title": "Mappatura scenari INIM → HomeKit",
      "expandable": true,
      "expanded": true,
      "items": [
        "scenarioDisarmed",
        "scenarioHome",
        "scenarioNight",
        "scenarioAway"
      ]
    },
    {
      "type": "section",
      "title": "Avanzate",
      "expandable": true,
      "expanded": false,
      "items": ["pollInterval"]
    }
  ]
}
