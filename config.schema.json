{
  "pluginAlias": "InimCloud",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Nome piattaforma",
        "type": "string",
        "default": "INIM Cloud",
        "required": true
      },
      "email": {
        "title": "Email account INIM Cloud",
        "type": "string",
        "required": true
      },
      "password": {
        "title": "Password account INIM Cloud",
        "type": "string",
        "required": true
      },
      "userCode": {
        "title": "PIN utente allarme (codice tastiera)",
        "type": "string",
        "required": true
      },
      "accessoryName": {
        "title": "Nome accessorio in HomeKit",
        "type": "string",
        "default": "Allarme Casa"
      },
      "scenarioDisarmed": {
        "title": "Scenario INIM → Disarmato",
        "type": "integer",
        "default": 0,
        "description": "ID scenario INIM per stato Disarmato"
      },
      "scenarioHome": {
        "title": "Scenario INIM → Casa (Stay Armed)",
        "type": "integer",
        "default": 1,
        "description": "ID scenario INIM per stato Casa"
      },
      "scenarioNight": {
        "title": "Scenario INIM → Notte (Night Armed)",
        "type": "integer",
        "default": 2,
        "description": "ID scenario INIM per stato Notte"
      },
      "scenarioAway": {
        "title": "Scenario INIM → Fuori (Away Armed)",
        "type": "integer",
        "default": 3,
        "description": "ID scenario INIM per stato Fuori"
      },
      "pollInterval": {
        "title": "Intervallo aggiornamento stato (secondi)",
        "type": "integer",
        "default": 15,
        "minimum": 5
      }
    }
  },
  "layout": [
    {
      "type": "section",
      "title": "Credenziali INIM Cloud",
      "items": ["name", "email", "password", "userCode", "accessoryName"]
    },
    {
      "type": "section",
      "title": "Mappatura scenari INIM → HomeKit",
      "expandable": true,
      "expanded": true,
      "items": ["scenarioDisarmed", "scenarioHome", "scenarioNight", "scenarioAway"]
    },
    {
      "type": "section",
      "title": "Avanzate",
      "expandable": true,
      "expanded": false,
      "items": ["pollInterval"]
    }
  ]
}
